/target
**/*.rs.bk
.DS_Store
.env
# Editor swap/backup files
*.swp
*.swo
*~
# Terraform local state + provider cache (never commit — may hold secrets, and the provider docs
# under .terraform/ would trip markdownlint)
.terraform/
*.tfstate
*.tfstate.*
deploy/iac/terraform.tfvars
/deploy/compose/data
/data
# Python bytecode (bench/ tooling + the scale-test harness)
__pycache__/
*.pyc
# Rendered per-workload k8s manifests — regenerate with `harness.py render <workload>`
/bench/scale/.render/
.claude/
/bench/scale/runs/
# Packaged tarballs (Helm charts, npm packs) — build artifacts, never committed
*.tgz

# Local embedding-model cache for the demo stack (fallback when GROWLERDB_MODEL_DIR is unset)
deploy/compose/model-cache/
deploy/compose/demo-data/local/*
!deploy/compose/demo-data/local/.gitkeep
# local docs preview only — GitHub Pages' native build pins its own gem set
docs/Gemfile.lock
