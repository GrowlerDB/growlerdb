# GrowlerDB against your own external Iceberg table — copy to `.env` and edit.
#   cp .env.external.example .env
#   docker compose -f external.yml up
# Used by external.yml (the query/hydration side). The Spark connector (ongoing ingestion)
# is configured separately — see docs/external-iceberg.md. `.env` is gitignored.

# --- Iceberg REST catalog (Polaris / Nessie / any Iceberg REST catalog) ---
# GrowlerDB's engine speaks the Iceberg REST protocol only (no Glue/Hadoop catalog).
GROWLERDB_CATALOG_URI=https://your-catalog.example.com/api/catalog
GROWLERDB_WAREHOUSE=your_warehouse          # for Polaris this is the catalog name
# OAuth2 for the catalog (Polaris). Leave BOTH empty for a catalog that needs no auth.
GROWLERDB_CATALOG_CREDENTIAL=client_id:client_secret
GROWLERDB_CATALOG_SCOPE=PRINCIPAL_ROLE:ALL

# --- S3-compatible object store ---
# Real AWS S3: use https://s3.<region>.amazonaws.com and static access keys (no IAM role/STS).
# MinIO / other: your endpoint. NOTE: the engine forces path-style S3 access (works with MinIO
# and still works with AWS S3 today).
GROWLERDB_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
GROWLERDB_S3_ACCESS_KEY=AKIAEXAMPLE
GROWLERDB_S3_SECRET_KEY=your-secret-key
GROWLERDB_S3_REGION=us-east-1

# --- Your table + the index to build over it ---
GROWLERDB_SOURCE_TABLE=your_namespace.your_table   # namespace.table
GROWLERDB_INDEX_NAME=your_index

# --- Login + mesh secrets (rotate for anything beyond a local experiment) ---
# Your login user. Pick any name EXCEPT `admin`: `admin` is the reserved built-in superuser, seeded
# with a RANDOM password (printed once in the control-plane logs) unless you set
# GROWLERDB_ADMIN_PASSWORD below — so naming your login `admin` makes GROWLERDB_LOGIN_PASSWORD have no
# effect. This login gets reader + operator, scoped to GROWLERDB_INDEX_NAME.
GROWLERDB_LOGIN_USER=demo
GROWLERDB_LOGIN_PASSWORD=change-me
GROWLERDB_SERVICE_TOKEN=change-me-shared-mesh-token
GROWLERDB_AUTH_SECRET=change-me-gateway-hs256-secret

# --- Optional ---
# Give the built-in `admin` superuser a known password (full control: manage indexes, tokens, users).
# Leave unset to get a random one printed once in the control-plane logs.
# GROWLERDB_ADMIN_PASSWORD=change-me-admin
#
# Pin a specific release instead of floating on :latest (the external.yml default).
# GROWLERDB_IMAGE=ghcr.io/growlerdb/growlerdb:v0.3.0
#
# Catalog/object store running in ANOTHER Compose stack (e.g. growlerdb-dev), reachable only by
# in-network hostnames like `polaris` / `minio`? Join that stack's network — see the `networks` note
# at the bottom of external.yml.
